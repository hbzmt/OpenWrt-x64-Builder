config interface 'loopback'
    option device 'lo'
    option proto 'static'
    option ipaddr '127.0.0.1'
    option netmask '255.0.0.0'

config device
    option name 'br-lan'
    option type 'bridge'
    list ports 'eth0'

config interface 'lan'
    option device 'br-lan'
    option proto 'static'
    option ipaddr '10.0.0.99'
    option netmask '255.255.255.0'
    option gateway '10.0.0.2'
    option dns '10.0.0.7'
    option ip6assign '60'

config interface 'ipv6' 
    option proto 'dhcpv6' 
    option device '@lan' 
    option reqaddress 'try' 
    option reqprefix 'auto' 
    option norelease '1' 
    option sourcefilter '0'
